[user]
	email = t_chuck_flowers@yahoo.com
	name = Chuck Flowers
[core]
	editor = nvim
[alias]
	l = log --all --decorate --oneline --graph
	lb = log --decorate --oneline --graph
	rd = rebase -i master
	rr = rebase -i origin

# Command Configuration
[branch]
	sort = -committerdate
[diff]
	algorithm = histogram
	colorMoved = plain
	external = difft
[fetch]
	all = true
	pruneTags = true
[init]
	defaultBranch = master
[merge]
	ff = only
[pull]
	ff = only
	rebase = true
[push]
	autoSetupRemote = true
	followTags = true
[rebase]
	autoSquash = true
	autoStash = true
	updateRefs = true
[tag]
	sort = version:refname

# Credentials
[credential "https://github.com"]
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = !/usr/bin/gh auth git-credential
